# ─────────────────────────────────────────────────────────────
# Limud v9.7.7 — Environment Variables
# Copy this file to .env and fill in your production values.
# ─────────────────────────────────────────────────────────────

# ─── Database (PostgreSQL) ─────────────────────────────────
# Recommended providers:
#   - Neon (neon.tech)        — Free tier, serverless PostgreSQL
#   - Supabase (supabase.com) — Free tier, PostgreSQL + extras
#   - Railway (railway.app)   — Easy setup, PostgreSQL
#   - Render PostgreSQL       — Managed DB alongside your app ($7/mo)
#
# If deploying to Render, you can create a PostgreSQL database
# in the Render dashboard and it will auto-inject DATABASE_URL.
DATABASE_URL="postgresql://user:password@host:5432/limud?sslmode=require"

# ─── NextAuth.js ──────────────────────────────────────────
# NEXTAUTH_URL: Your full production domain (with https://)
# For Render deployment with limud.co:
NEXTAUTH_URL="https://limud.co"

# NEXTAUTH_SECRET: Generate a random secret:
#   openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_generate_a_random_secret_here"

# ─── Google Gemini API (for AI Tutor, Auto-Grader, Quiz Generator) ────
# Get your API key from https://aistudio.google.com/apikey
# Set to "demo-mode" to run without AI (uses fallback responses)
# v9.7.7: Default model is now gemini-2.5-flash (paid tier 1)
GEMINI_API_KEY="your-gemini-api-key-here"

# Optional: Override the default model (gemini-2.5-flash)
# Supported: gemini-2.0-flash, gemini-2.5-flash, gemini-2.5-pro
# AI_MODEL="gemini-2.5-flash"

# ─── App Configuration ────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Limud"
NEXT_PUBLIC_APP_URL="https://limud.co"
NODE_ENV="production"

# ─── Render-Specific ─────────────────────────────────────
# PORT is set automatically by Render — do NOT set manually.
# RENDER=true is injected automatically by Render's runtime.
# RENDER_EXTERNAL_URL is the .onrender.com URL (set automatically).

# ─── cPanel-Specific (set by Passenger automatically) ─────
# PORT is set automatically by cPanel Passenger — do NOT set manually
# HOSTNAME defaults to 0.0.0.0 — do NOT change unless needed
