// Prisma schema for Limud EdTech Platform v2.0
// Adaptive AI-Powered K-12 Platform with Cognitive Science Engine
// Covers: Users (RBAC), Districts, Assignments, Submissions, AI Logs, Gamification,
//   Lesson Plans, Skill Tracking, Spaced Repetition, Study Planner, Exam Simulation,
//   Leagues & Tournaments, Mistake Replay, Growth Analytics

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  TEACHER
  ADMIN
  PARENT
}

enum AccountType {
  DISTRICT
  HOMESCHOOL
  INDIVIDUAL
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  GRADING
  GRADED
  RETURNED
}

enum AssignmentType {
  ESSAY
  MULTIPLE_CHOICE
  SHORT_ANSWER
  PROJECT
  QUIZ
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRED
  CANCELLED
}

enum SubscriptionTier {
  FREE
  STARTER
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum Difficulty {
  BEGINNER
  EASY
  MEDIUM
  HARD
  ADVANCED
}

// ─── SCHOOL DISTRICT ────────────────────────────────────────────────────────

model SchoolDistrict {
  id                String             @id @default(cuid())
  name              String
  subdomain         String             @unique
  contactEmail      String
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  subscriptionTier  SubscriptionTier   @default(FREE)
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  pricePerYear      Float              @default(0)
  maxStudents       Int                @default(5)
  maxTeachers       Int                @default(1)
  isHomeschool      Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  users             User[]
  courses           Course[]

  @@map("school_districts")
}

// ─── USER ───────────────────────────────────────────────────────────────────

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  password       String // bcrypt hashed
  role           Role
  accountType    AccountType     @default(DISTRICT)
  avatarUrl      String?
  selectedAvatar String          @default("default")
  selectedTheme  String          @default("default") // unlockable themes
  isActive       Boolean         @default(true)
  isDemo         Boolean         @default(false)
  districtId     String?
  gradeLevel     String?         // For students: "5th", "6th", etc.
  parentId       String?         // Links student to parent
  onboardingComplete Boolean     @default(false)
  preferredTutor String          @default("socratic") // tutor personality
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  district       SchoolDistrict? @relation(fields: [districtId], references: [id], onDelete: SetNull)
  parent         User?           @relation("ParentChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children       User[]          @relation("ParentChildren")

  // Teacher relations
  taughtCourses  CourseTeacher[]
  createdAssignments Assignment[]
  lessonPlans    LessonPlan[]
  quizTemplates  QuizTemplate[]

  // Student relations
  enrollments    Enrollment[]
  submissions    Submission[]
  rewardStats    RewardStats?
  tutorLogs      AITutorLog[]
  notifications  Notification[]
  certificates   Certificate[]

  // Adaptive learning relations
  skillRecords       SkillRecord[]
  spacedRepItems     SpacedRepItem[]
  studyPlanSessions  StudyPlanSession[]
  examAttempts       ExamAttempt[]
  mistakeEntries     MistakeEntry[]
  challengeParticipants ChallengeParticipant[]
  weeklyReports      WeeklyReport[]

  // v3 New feature relations
  learningDNA        LearningDNA?
  focusSessions      FocusSession[]
  emotionalCheckins  EmotionalCheckin[]
  microLessons       MicroLesson[]
  homeworkScans      HomeworkScan[]
  whiteboardMembers  WhiteboardMember[]
  goalContracts      GoalContract[]
  conceptMaps        ConceptMap[]
  vocabEntries       VocabEntry[]
  interventionPlans  InterventionPlan[]  // teacher creates
  parentGoals        ParentGoal[]
  peerTutorOfferings PeerTutorMatch[]    @relation("TutorOfferings")
  peerTutorRequests  PeerTutorMatch[]    @relation("TuteeRequests")
  progressSnapshots  ProgressSnapshot[]
  writingSubmissions WritingSubmission[]
  mathAttempts       MathStepAttempt[]

  // v3.1 Engagement & intelligence
  confidenceRatings  ConfidenceRating[]
  seasonPassProgress SeasonPassProgress[]
  dailyBoosts        DailyBoost[]
  studyGroupMembers  StudyGroupMember[]
  questionPosts      QuestionPost[]
  questionVotes      QuestionVote[]
  marketplaceListings MarketplaceListing[]

  // Auth sessions
  sessions       Session[]
  accounts       Account[]

  // Messaging
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  @@index([email])
  @@index([role])
  @@index([districtId])
  @@index([parentId])
  @@map("users")
}

// ─── AUTH (NextAuth.js) ─────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── COURSE ─────────────────────────────────────────────────────────────────

model Course {
  id          String      @id @default(cuid())
  name        String
  description String?
  subject     String
  gradeLevel  String
  districtId  String
  isActive    Boolean     @default(true)
  standards   String?     @db.Text  // JSON: aligned standards (Common Core, NGSS, etc.)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  district    SchoolDistrict @relation(fields: [districtId], references: [id], onDelete: Cascade)
  teachers    CourseTeacher[]
  enrollments Enrollment[]
  assignments Assignment[]
  skillRecords SkillRecord[]

  @@index([districtId])
  @@map("courses")
}

model CourseTeacher {
  id        String   @id @default(cuid())
  courseId   String
  teacherId  String
  assignedAt DateTime @default(now())

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher User   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([courseId, teacherId])
  @@map("course_teachers")
}

model Enrollment {
  id         String   @id @default(cuid())
  courseId    String
  studentId  String
  enrolledAt DateTime @default(now())

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@map("enrollments")
}

// ─── ASSIGNMENT ─────────────────────────────────────────────────────────────

model Assignment {
  id            String         @id @default(cuid())
  title         String
  description   String         @db.Text
  type          AssignmentType
  courseId       String
  createdById    String
  dueDate       DateTime
  totalPoints   Int            @default(100)
  rubric        String?        @db.Text  // JSON rubric for AI grading
  isPublished   Boolean        @default(false)
  allowLateSubmission Boolean  @default(false)
  difficulty    Difficulty     @default(MEDIUM)
  skills        String?        @db.Text  // JSON array of skill tags
  standards     String?        @db.Text  // JSON aligned standards
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  course     Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy  User        @relation(fields: [createdById], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([courseId])
  @@index([dueDate])
  @@map("assignments")
}

// ─── SUBMISSION ─────────────────────────────────────────────────────────────

model Submission {
  id            String           @id @default(cuid())
  assignmentId  String
  studentId     String
  content       String           @db.Text  // The student's answer
  status        SubmissionStatus @default(PENDING)
  score         Float?
  maxScore      Float?
  aiFeedback    String?          @db.Text  // AI-generated personalized feedback
  teacherNotes  String?          @db.Text  // Teacher override/additional notes
  misconceptions String?        @db.Text  // JSON: AI-detected misconceptions
  gradedAt      DateTime?
  submittedAt   DateTime?
  timeSpentSec  Int?             // Time student spent
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mistakeEntries MistakeEntry[]

  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@index([status])
  @@map("submissions")
}

// ─── AI TUTOR LOG ───────────────────────────────────────────────────────────

model AITutorLog {
  id          String   @id @default(cuid())
  userId      String
  sessionId   String   // Groups messages in a conversation
  role        String   // "user" | "assistant" | "system"
  content     String   @db.Text
  subject     String?  // What subject the question relates to
  personality String?  // Tutor personality used: socratic, friendly, strict, creative
  tokensUsed  Int      @default(0)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId])
  @@index([createdAt])
  @@map("ai_tutor_logs")
}

// ─── GAMIFICATION / REWARD STATS ────────────────────────────────────────────

model RewardStats {
  id               String   @id @default(cuid())
  userId           String   @unique
  totalXP          Int      @default(0)
  level            Int      @default(1)
  currentStreak    Int      @default(0)
  longestStreak    Int      @default(0)
  lastActiveDate   DateTime @default(now())
  virtualCoins     Int      @default(0)
  unlockedAvatars  String   @default("[]") // JSON array of unlocked avatar IDs
  unlockedBadges   String   @default("[]") // JSON array of badge IDs
  unlockedThemes   String   @default("[]") // JSON array of theme IDs
  assignmentsCompleted Int  @default(0)
  tutorSessionsCount   Int  @default(0)
  perfectScores    Int      @default(0)
  totalStudyMinutes Int     @default(0)
  leaguePoints     Int      @default(0)
  seasonRank       Int?     // Current season ranking
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reward_stats")
}

// ─── NOTIFICATIONS ──────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // "assignment", "grade", "achievement", "system", "alert", "challenge"
  isRead    Boolean  @default(false)
  link      String?  // Optional navigation link
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── LESSON PLANS (AI-Generated) ────────────────────────────────────────────

model LessonPlan {
  id            String   @id @default(cuid())
  teacherId     String
  title         String
  subject       String
  gradeLevel    String
  duration      String   // e.g., "45 min", "1 hour"
  objectives    String   @db.Text  // JSON array of learning objectives
  standards     String?  @db.Text  // Aligned standards (e.g., Common Core)
  materials     String?  @db.Text  // JSON array of materials needed
  warmUp        String?  @db.Text  // Opening activity
  directInstruction String? @db.Text  // Main teaching content
  guidedPractice String?  @db.Text  // Guided practice activity
  independentPractice String? @db.Text  // Student independent work
  assessment    String?  @db.Text  // How learning is assessed
  closure       String?  @db.Text  // Closing activity
  differentiation String? @db.Text  // Accommodations for different learners
  homework      String?  @db.Text  // Homework assignment
  notes         String?  @db.Text  // Additional teacher notes
  aiGenerated   Boolean  @default(true)
  isFavorite    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  teacher User @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([subject])
  @@map("lesson_plans")
}

// ─── CERTIFICATES ───────────────────────────────────────────────────────────

model Certificate {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  type        String   // "course_completion", "achievement", "milestone"
  metadata    String?  @db.Text  // JSON with additional data
  issuedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("certificates")
}

// ─── MESSAGES (Parent-Teacher Communication) ────────────────────────────────

model Message {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  subject     String
  content     String   @db.Text
  isRead      Boolean  @default(false)
  parentOf    String?  // Student ID this message is about
  createdAt   DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}

// ═══════════════════════════════════════════════════════════════════════════
// NEW: ADAPTIVE LEARNING & COGNITIVE SCIENCE ENGINE
// ═══════════════════════════════════════════════════════════════════════════

// ─── SKILL TRACKING ────────────────────────────────────────────────────────

model SkillRecord {
  id             String   @id @default(cuid())
  userId         String
  courseId        String?
  skillName      String   // e.g., "Fractions", "Photosynthesis", "Essay Structure"
  skillCategory  String   // e.g., "Math", "Science", "ELA"
  masteryLevel   Float    @default(0)  // 0-100 mastery percentage
  totalAttempts  Int      @default(0)
  correctAttempts Int     @default(0)
  currentDifficulty Difficulty @default(MEDIUM)
  lastPracticed  DateTime @default(now())
  nextReview     DateTime @default(now()) // spaced rep next review
  easeFactor     Float    @default(2.5)  // SM-2 algorithm ease factor
  interval       Int      @default(1)    // days until next review
  repetitions    Int      @default(0)
  streak         Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@unique([userId, skillName, courseId])
  @@index([userId, nextReview])
  @@index([userId, skillCategory])
  @@map("skill_records")
}

// ─── SPACED REPETITION ITEMS ───────────────────────────────────────────────

model SpacedRepItem {
  id            String   @id @default(cuid())
  userId        String
  question      String   @db.Text
  answer        String   @db.Text
  skillName     String
  subject       String
  difficulty    Difficulty @default(MEDIUM)
  easeFactor    Float    @default(2.5)
  interval      Int      @default(1)    // days
  repetitions   Int      @default(0)
  nextReview    DateTime @default(now())
  lastReview    DateTime?
  lastQuality   Int?     // 0-5 quality of last response
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, nextReview])
  @@index([userId, subject])
  @@map("spaced_rep_items")
}

// ─── STUDY PLANNER ─────────────────────────────────────────────────────────

model StudyPlanSession {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime // planned date
  subject       String
  topic         String
  goalMinutes   Int      @default(30)
  actualMinutes Int      @default(0)
  completed     Boolean  @default(false)
  sessionType   String   @default("study") // "study", "review", "practice", "exam_prep"
  difficulty    Difficulty @default(MEDIUM)
  notes         String?  @db.Text
  aiRecommended Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("study_plan_sessions")
}

// ─── EXAM SIMULATION ───────────────────────────────────────────────────────

model ExamAttempt {
  id            String   @id @default(cuid())
  userId        String
  examTitle     String
  subject       String
  gradeLevel    String
  totalQuestions Int
  correctAnswers Int     @default(0)
  score         Float?
  maxScore      Float?
  timeSpentSec  Int?
  timeLimitSec  Int?
  questions     String   @db.Text  // JSON: array of {question, options, correctAnswer, userAnswer, explanation}
  strengths     String?  @db.Text  // JSON: skill areas of strength
  weaknesses    String?  @db.Text  // JSON: skill areas needing work
  predictedScore Float?  // AI-predicted real exam score
  completed     Boolean  @default(false)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, subject])
  @@index([userId, createdAt])
  @@map("exam_attempts")
}

// ─── MISTAKE REPLAY / ERROR DIAGNOSIS ──────────────────────────────────────

model MistakeEntry {
  id            String   @id @default(cuid())
  userId        String
  submissionId  String?
  subject       String
  skillName     String
  question      String   @db.Text
  wrongAnswer   String   @db.Text
  correctAnswer String   @db.Text
  explanation   String?  @db.Text  // AI explanation of misconception
  misconceptionType String? // e.g., "sign_error", "concept_confusion", "formula_misapplication"
  resolved      Boolean  @default(false)
  reviewCount   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  submission Submission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  @@index([userId, resolved])
  @@index([userId, subject])
  @@map("mistake_entries")
}

// ─── QUIZ TEMPLATES (AI-Generated for Teachers) ────────────────────────────

model QuizTemplate {
  id            String   @id @default(cuid())
  teacherId     String
  title         String
  subject       String
  gradeLevel    String
  difficulty    Difficulty @default(MEDIUM)
  questionCount Int      @default(10)
  questions     String   @db.Text  // JSON: array of {question, type, options, correctAnswer, explanation, skill}
  standards     String?  @db.Text  // JSON: aligned standards
  aiGenerated   Boolean  @default(true)
  isFavorite    Boolean  @default(false)
  timesUsed     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  teacher User @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@map("quiz_templates")
}

// ─── CHALLENGES & TOURNAMENTS ──────────────────────────────────────────────

model Challenge {
  id            String   @id @default(cuid())
  title         String
  description   String?
  subject       String
  type          String   // "duel", "tournament", "weekly", "seasonal"
  difficulty    Difficulty @default(MEDIUM)
  questions     String   @db.Text  // JSON: array of challenge questions
  maxParticipants Int    @default(50)
  xpReward      Int      @default(100)
  coinReward    Int      @default(50)
  startsAt      DateTime
  endsAt        DateTime
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  participants  ChallengeParticipant[]

  @@index([isActive, startsAt])
  @@map("challenges")
}

model ChallengeParticipant {
  id            String   @id @default(cuid())
  challengeId   String
  userId        String
  score         Float?
  timeSpentSec  Int?
  rank          Int?
  completed     Boolean  @default(false)
  answers       String?  @db.Text  // JSON: user's answers
  joinedAt      DateTime @default(now())
  completedAt   DateTime?

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([userId])
  @@map("challenge_participants")
}

// ─── WEEKLY REPORTS (Parent) ───────────────────────────────────────────────

model WeeklyReport {
  id            String   @id @default(cuid())
  userId        String   // student
  weekStart     DateTime
  weekEnd       DateTime
  totalStudyMin Int      @default(0)
  assignmentsCompleted Int @default(0)
  averageScore  Float?
  skillsImproved String? @db.Text  // JSON: skills that improved
  skillsStruggling String? @db.Text // JSON: skills needing help
  streakDays    Int      @default(0)
  xpEarned      Int      @default(0)
  tutorSessions Int      @default(0)
  focusScore    Float?   // 0-100 engagement/focus metric
  effortScore   Float?   // 0-100 effort metric
  riskLevel     String?  // "low", "medium", "high"
  aiSummary     String?  @db.Text  // AI-generated narrative summary
  projectedGrade String? // Predicted grade if trend continues
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekStart])
  @@map("weekly_reports")
}

// ═══════════════════════════════════════════════════════════════════════════
// V3: 20 NEW FEATURES - Intelligence, Focus, Social, Analytics
// ═══════════════════════════════════════════════════════════════════════════

// ─── 1. LEARNING DNA PROFILE ─────────────────────────────────────────────

model LearningDNA {
  id                String   @id @default(cuid())
  userId            String   @unique
  learningSpeed     Float    @default(1.0)
  retentionRate     Float    @default(0.7)
  preferredModality String   @default("visual")
  peakHourStart     Int      @default(9)
  peakHourEnd       Int      @default(11)
  avgSessionMinutes Int      @default(25)
  optimalChunkSize  Int      @default(5)
  attentionSpanMin  Int      @default(20)
  subjectStrengths  String   @default("{}") @db.Text
  subjectWeaknesses String   @default("{}") @db.Text
  learningPatterns  String   @default("{}") @db.Text
  lastUpdated       DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("learning_dna")
}

// ─── 2. FOCUS SESSIONS ───────────────────────────────────────────────────

model FocusSession {
  id              String    @id @default(cuid())
  userId          String
  subject         String
  topic           String?
  plannedMinutes  Int       @default(25)
  actualMinutes   Int       @default(0)
  breakMinutes    Int       @default(5)
  focusScore      Float?
  distractionCount Int      @default(0)
  completed       Boolean   @default(false)
  sessionType     String    @default("pomodoro")
  itemsCompleted  Int       @default(0)
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@map("focus_sessions")
}

// ─── 3. EMOTIONAL CHECK-INS ──────────────────────────────────────────────

model EmotionalCheckin {
  id          String   @id @default(cuid())
  userId      String
  mood        String
  energy      Int      @default(3)
  confidence  Int      @default(3)
  context     String?
  notes       String?  @db.Text
  aiResponse  String?  @db.Text
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("emotional_checkins")
}

// ─── 4. AI MICRO-LESSONS ─────────────────────────────────────────────────

model MicroLesson {
  id            String     @id @default(cuid())
  userId        String?
  subject       String
  topic         String
  title         String
  content       String     @db.Text
  durationMin   Int        @default(3)
  difficulty    Difficulty @default(MEDIUM)
  skillTags     String?    @db.Text
  completions   Int        @default(0)
  avgRating     Float      @default(0)
  aiGenerated   Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  creator User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([subject, difficulty])
  @@map("micro_lessons")
}

// ─── 5. HOMEWORK SCANNER ─────────────────────────────────────────────────

model HomeworkScan {
  id              String   @id @default(cuid())
  userId          String
  imageUrl        String?  @db.Text
  extractedText   String?  @db.Text
  subject         String
  autoGrade       Float?
  feedback        String?  @db.Text
  corrections     String?  @db.Text
  skillsDetected  String?  @db.Text
  status          String   @default("pending")
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("homework_scans")
}

// ─── 6. COLLABORATIVE WHITEBOARD ─────────────────────────────────────────

model Whiteboard {
  id          String   @id @default(cuid())
  title       String
  subject     String?
  boardData   String   @default("{}") @db.Text
  isPublic    Boolean  @default(false)
  maxMembers  Int      @default(5)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members WhiteboardMember[]

  @@map("whiteboards")
}

model WhiteboardMember {
  id           String   @id @default(cuid())
  whiteboardId String
  userId       String
  role         String   @default("editor")
  joinedAt     DateTime @default(now())

  whiteboard Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([whiteboardId, userId])
  @@map("whiteboard_members")
}

// ─── 7. AI GOAL-CONTRACT SYSTEM ──────────────────────────────────────────

model GoalContract {
  id              String   @id @default(cuid())
  userId          String
  title           String
  description     String   @db.Text
  targetType      String
  targetValue     Float
  currentValue    Float    @default(0)
  startDate       DateTime @default(now())
  endDate         DateTime
  reward          String?
  status          String   @default("active")
  checkpoints     String?  @db.Text
  aiCoachNotes    String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("goal_contracts")
}

// ─── 8. AI CONCEPT MAP ───────────────────────────────────────────────────

model ConceptMap {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  topic       String
  nodes       String   @db.Text
  edges       String   @db.Text
  summary     String?  @db.Text
  aiGenerated Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, subject])
  @@map("concept_maps")
}

// ─── 9. VOCABULARY VAULT ─────────────────────────────────────────────────

model VocabEntry {
  id            String    @id @default(cuid())
  userId        String
  word          String
  definition    String    @db.Text
  partOfSpeech  String?
  example       String?   @db.Text
  pronunciation String?
  subject       String    @default("ELA")
  imageUrl      String?
  mnemonicHint  String?   @db.Text
  masteryLevel  Float     @default(0)
  easeFactor    Float     @default(2.5)
  interval      Int       @default(1)
  repetitions   Int       @default(0)
  nextReview    DateTime  @default(now())
  lastReview    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, word, subject])
  @@index([userId, nextReview])
  @@map("vocab_entries")
}

// ─── 10. TEACHER INTERVENTION PLANS ──────────────────────────────────────

model InterventionPlan {
  id              String   @id @default(cuid())
  teacherId       String
  studentId       String?
  title           String
  targetSkills    String   @db.Text
  strategies      String   @db.Text
  milestones      String?  @db.Text
  status          String   @default("draft")
  progressNotes   String?  @db.Text
  aiGenerated     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  teacher User @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId, status])
  @@map("intervention_plans")
}

// ─── 11. PARENT GOAL TRACKING ────────────────────────────────────────────

model ParentGoal {
  id          String   @id @default(cuid())
  parentId    String
  childId     String?
  title       String
  category    String
  targetValue String
  currentValue String?
  notes       String?  @db.Text
  milestones  String?  @db.Text
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent User @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId, status])
  @@map("parent_goals")
}

// ─── 12. PEER TUTORING MATCHING ──────────────────────────────────────────

model PeerTutorMatch {
  id          String   @id @default(cuid())
  tutorId     String
  tuteeId     String
  subject     String
  skillName   String
  status      String   @default("pending")
  sessionCount Int     @default(0)
  rating      Float?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tutor User @relation("TutorOfferings", fields: [tutorId], references: [id], onDelete: Cascade)
  tutee User @relation("TuteeRequests", fields: [tuteeId], references: [id], onDelete: Cascade)

  @@index([tutorId])
  @@index([tuteeId])
  @@map("peer_tutor_matches")
}

// ─── 13. PROGRESS SNAPSHOT ───────────────────────────────────────────────

model ProgressSnapshot {
  id              String   @id @default(cuid())
  userId          String
  period          String
  periodStart     DateTime
  periodEnd       DateTime
  overallGrade    String?
  gpa             Float?
  subjectGrades   String   @db.Text
  achievements    String?  @db.Text
  teacherComments String?  @db.Text
  aiNarrative     String?  @db.Text
  strengths       String?  @db.Text
  areasForGrowth  String?  @db.Text
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, periodStart])
  @@map("progress_snapshots")
}

// ─── 14. AI WRITING COACH ────────────────────────────────────────────────

model WritingSubmission {
  id              String   @id @default(cuid())
  userId          String
  title           String?
  content         String   @db.Text
  writingType     String   @default("essay")
  rubricUsed      String?  @db.Text
  scores          String?  @db.Text
  overallScore    Float?
  feedback        String?  @db.Text
  suggestions     String?  @db.Text
  wordCount       Int      @default(0)
  readabilityGrade Float?
  revisionNumber  Int      @default(1)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("writing_submissions")
}

// ─── 15. STEP-BY-STEP MATH SOLVER ────────────────────────────────────────

model MathStepAttempt {
  id              String   @id @default(cuid())
  userId          String
  problem         String   @db.Text
  studentSteps    String   @db.Text
  correctSteps    String?  @db.Text
  errorStep       Int?
  errorType       String?
  hintGiven       String?  @db.Text
  isCorrect       Boolean  @default(false)
  subject         String   @default("math")
  topic           String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("math_step_attempts")
}

// ═══════════════════════════════════════════════════════════════════════════
// V3.1: CONFIDENCE, ENGAGEMENT, SOCIAL, MARKETPLACE
// ═══════════════════════════════════════════════════════════════════════════

model ConfidenceRating {
  id           String   @id @default(cuid())
  userId       String
  questionId   String?  // links to assignment question or spaced rep item
  subject      String
  skillName    String?
  confidence   Int      // 1-5 how sure they are
  wasCorrect   Boolean
  isLuckyGuess Boolean  @default(false) // high confidence + wrong OR low confidence + right
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, subject])
  @@map("confidence_ratings")
}

model SeasonPassProgress {
  id          String   @id @default(cuid())
  userId      String
  season      String   // "2026-spring", "2026-summer"
  tier        Int      @default(0) // 0=free, 1=bronze, 2=silver, 3=gold
  currentXP   Int      @default(0)
  missions    String   @default("[]") @db.Text // JSON: [{id, title, xpReward, completed}]
  rewards     String   @default("[]") @db.Text // JSON: unlocked rewards
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, season])
  @@map("season_pass_progress")
}

model DailyBoost {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime @default(now())
  questionsAsked Int     @default(0)
  questionsCorrect Int   @default(0)
  xpEarned      Int      @default(0)
  timeSpentSec  Int      @default(0)
  streakSaved   Boolean  @default(false)
  completed     Boolean  @default(false)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("daily_boosts")
}

// ─── STUDY GROUPS (Academic Social) ──────────────────────────────────────

model StudyGroup {
  id          String   @id @default(cuid())
  name        String
  subject     String?
  description String?
  inviteCode  String   @unique @default(cuid())
  isPublic    Boolean  @default(false)
  maxMembers  Int      @default(10)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  StudyGroupMember[]
  messages StudyGroupMessage[]

  @@map("study_groups")
}

model StudyGroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      String   @default("member") // owner, moderator, member
  joinedAt  DateTime @default(now())

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("study_group_members")
}

model StudyGroupMessage {
  id        String   @id @default(cuid())
  groupId   String
  authorId  String
  content   String   @db.Text
  isAI      Boolean  @default(false)
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now())

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
  @@map("study_group_messages")
}

// ─── QUESTION FEED (Academic Q&A) ────────────────────────────────────────

model QuestionPost {
  id            String   @id @default(cuid())
  authorId      String
  subject       String
  title         String
  content       String   @db.Text
  aiSummary     String?  @db.Text
  isEndorsed    Boolean  @default(false)
  endorsedBy    String?  // teacher userId
  upvotes       Int      @default(0)
  answerCount   Int      @default(0)
  isClosed      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  author User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes  QuestionVote[]

  @@index([subject, createdAt])
  @@map("question_posts")
}

model QuestionVote {
  id         String   @id @default(cuid())
  postId     String
  userId     String
  isUpvote   Boolean  @default(true)
  createdAt  DateTime @default(now())

  post QuestionPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("question_votes")
}

// ─── TEACHER MARKETPLACE ─────────────────────────────────────────────────

model MarketplaceListing {
  id            String   @id @default(cuid())
  teacherId     String
  title         String
  description   String   @db.Text
  type          String   // lesson_pack, worksheet, quiz, curriculum
  subject       String
  gradeLevel    String
  price         Float    @default(0) // 0 = free
  content       String   @db.Text // JSON: the actual resource data
  standards     String?  @db.Text // JSON: aligned standards
  downloads     Int      @default(0)
  rating        Float    @default(0)
  ratingCount   Int      @default(0)
  isPublished   Boolean  @default(false)
  tags          String?  // comma-separated
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  teacher User @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([subject, type])
  @@index([teacherId])
  @@map("marketplace_listings")
}
