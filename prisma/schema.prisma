// Prisma schema for Limud EdTech Platform v5.0
// Adaptive AI-Powered K-12 Platform with Personalized Learning Engine
// Covers: Users (RBAC), Districts, Schools, Classes, Assignments, Submissions, AI Logs,
//   Gamification, Game Store, Skill Tracking, Spaced Repetition,
//   Study Planner, Exam Simulation, Leagues & Tournaments, Mistake Replay,
//   Growth Analytics, Payment/Billing, File Uploads, District Multi-Level Access

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  TEACHER
  ADMIN
  PARENT
}

enum AccountType {
  DISTRICT
  HOMESCHOOL
  INDIVIDUAL
  SELF_EDUCATION
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  GRADING
  GRADED
  RETURNED
}

enum AssignmentType {
  ESSAY
  MULTIPLE_CHOICE
  SHORT_ANSWER
  PROJECT
  QUIZ
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRED
  CANCELLED
}

enum SubscriptionTier {
  FREE
  STARTER
  CUSTOM
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum Difficulty {
  BEGINNER
  EASY
  MEDIUM
  HARD
  ADVANCED
}

enum DistrictAccessLevel {
  SUPERINTENDENT
  ASSISTANT_SUPERINTENDENT
  CURRICULUM_DIRECTOR
  PRINCIPAL
  VICE_PRINCIPAL
  DISTRICT_EMPLOYEE
  IT_ADMIN
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ─── SCHOOL DISTRICT ────────────────────────────────────────────────────────

model SchoolDistrict {
  id                String             @id @default(cuid())
  name              String
  subdomain         String             @unique
  contactEmail      String
  contactPhone      String?
  address           String?
  city              String?
  state             String?
  zipCode           String?
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  subscriptionTier  SubscriptionTier   @default(FREE)
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  pricePerYear      Float              @default(0)
  maxStudents       Int                @default(5)
  maxTeachers       Int                @default(1)
  maxSchools        Int                @default(1)
  isHomeschool      Boolean            @default(false)
  gamesEnabled      Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  users             User[]
  courses           Course[]
  schools           School[]
  payments          Payment[]
  districtAdmins    DistrictAdmin[]
  classrooms        Classroom[]

  @@map("school_districts")
}

// ─── SCHOOL (within a district) ────────────────────────────────────────────

model School {
  id          String   @id @default(cuid())
  districtId  String
  name        String
  address     String?
  city        String?
  state       String?
  zipCode     String?
  phone       String?
  principalId String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  district    SchoolDistrict @relation(fields: [districtId], references: [id], onDelete: Cascade)
  users       User[]         @relation("SchoolUsers")
  classrooms  Classroom[]

  @@index([districtId])
  @@map("schools")
}

// ─── CLASSROOM (class within a school) ─────────────────────────────────────

model Classroom {
  id          String   @id @default(cuid())
  name        String
  schoolId    String?
  districtId  String
  gradeLevel  String?
  subject     String?
  period      String?  // e.g., "Period 1", "Block A"
  teacherId   String?
  courseId    String?
  gamesDisabledDuringClass Boolean @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school     School?        @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  district   SchoolDistrict @relation(fields: [districtId], references: [id], onDelete: Cascade)
  students   ClassroomStudent[]

  @@index([schoolId])
  @@index([districtId])
  @@map("classrooms")
}

model ClassroomStudent {
  id          String   @id @default(cuid())
  classroomId String
  studentId   String
  enrolledAt  DateTime @default(now())

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classroomId, studentId])
  @@map("classroom_students")
}

// ─── DISTRICT ADMIN ACCESS ────────────────────────────────────────────────

model DistrictAdmin {
  id          String             @id @default(cuid())
  userId      String
  districtId  String
  accessLevel DistrictAccessLevel @default(DISTRICT_EMPLOYEE)
  canCreateAccounts   Boolean @default(false)
  canManageSchools    Boolean @default(false)
  canManageBilling    Boolean @default(false)
  canViewAllData      Boolean @default(false)
  canManageClasses    Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  district SchoolDistrict @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@unique([userId, districtId])
  @@map("district_admins")
}

// ─── PAYMENT / BILLING ──────────────────────────────────────────────────

model Payment {
  id            String        @id @default(cuid())
  districtId    String
  amount        Float
  currency      String        @default("usd")
  status        PaymentStatus @default(PENDING)
  paymentMethod String?       // "card", "bank_transfer", "purchase_order"
  stripePaymentId String?     @unique
  description   String?
  tier          SubscriptionTier @default(STARTER)
  studentCount  Int           @default(0)
  teacherCount  Int           @default(0)
  billingEmail  String?
  billingName   String?
  invoiceUrl    String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  district SchoolDistrict @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@index([districtId])
  @@index([status])
  @@map("payments")
}

// ─── GAME STORE ─────────────────────────────────────────────────────────

model Game {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  category    String   // "math", "word", "puzzle", "trivia", "typing"
  subject     String?  // optional alignment to subject
  thumbnailUrl String?
  gameUrl     String   @db.Text // embedded game URL or inline HTML
  xpCost      Int      @default(50)
  minGrade    String?  // "3rd" - minimum grade level
  maxGrade    String?  // "8th" - max grade level
  isEducational Boolean @default(true)
  isActive    Boolean  @default(true)
  playCount   Int      @default(0)
  avgRating   Float    @default(0)
  ratingCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchases   GamePurchase[]

  @@index([category])
  @@map("games")
}

model GamePurchase {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  xpSpent   Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@map("game_purchases")
}

model GameSession {
  id          String   @id @default(cuid())
  userId      String
  gameId      String
  score       Int?     @default(0)
  timeSpentSec Int?    @default(0)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, gameId])
  @@map("game_sessions")
}

// ─── USER ───────────────────────────────────────────────────────────────────

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  firstName      String?
  lastName       String?
  password       String // bcrypt hashed
  resetToken     String?   @unique
  resetTokenExp  DateTime?
  role           Role
  accountType    AccountType     @default(DISTRICT)
  avatarUrl      String?
  selectedAvatar String          @default("default")
  selectedTheme  String          @default("default") // unlockable themes
  colorTheme     String          @default("blue")    // "blue" | "green" — app-wide color theme
  isActive       Boolean         @default(true)
  isDemo         Boolean         @default(false)
  districtId     String?
  schoolId       String?
  gradeLevel     String?         // For students: "5th", "6th", etc.
  parentId       String?         // Links student to parent
  siblingGroupId String?         // Groups siblings together
  // Student personal info (required by district)
  address        String?
  city           String?
  state          String?
  zipCode        String?
  phone          String?
  dateOfBirth    DateTime?
  emergencyContact String?
  emergencyPhone String?
  onboardingComplete Boolean     @default(false)
  surveyCompleted    Boolean     @default(false)
  preferredTutor String          @default("socratic") // tutor personality
  learningStyleProfile String?   @db.Text             // JSON: detailed learning style preferences from onboarding
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  district       SchoolDistrict? @relation(fields: [districtId], references: [id], onDelete: SetNull)
  school         School?         @relation("SchoolUsers", fields: [schoolId], references: [id], onDelete: SetNull)
  parent         User?           @relation("ParentChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children       User[]          @relation("ParentChildren")

  // Teacher relations
  taughtCourses  CourseTeacher[]
  createdAssignments Assignment[]
  quizTemplates  QuizTemplate[]

  // Student relations
  enrollments    Enrollment[]
  submissions    Submission[]
  rewardStats    RewardStats?
  tutorLogs      AITutorLog[]
  notifications  Notification[]
  certificates   Certificate[]

  // Adaptive learning relations
  skillRecords       SkillRecord[]
  spacedRepItems     SpacedRepItem[]
  studyPlanSessions  StudyPlanSession[]
  examAttempts       ExamAttempt[]
  mistakeEntries     MistakeEntry[]
  challengeParticipants ChallengeParticipant[]
  weeklyReports      WeeklyReport[]

  // v3 New feature relations
  learningDNA        LearningDNA?
  studentSurvey      StudentSurvey?
  focusSessions      FocusSession[]
  emotionalCheckins  EmotionalCheckin[]
  microLessons       MicroLesson[]
  homeworkScans      HomeworkScan[]
  whiteboardMembers  WhiteboardMember[]
  goalContracts      GoalContract[]
  conceptMaps        ConceptMap[]
  vocabEntries       VocabEntry[]
  interventionPlans  InterventionPlan[]  // teacher creates
  parentGoals        ParentGoal[]
  peerTutorOfferings PeerTutorMatch[]    @relation("TutorOfferings")
  peerTutorRequests  PeerTutorMatch[]    @relation("TuteeRequests")
  progressSnapshots  ProgressSnapshot[]
  writingSubmissions WritingSubmission[]
  mathAttempts       MathStepAttempt[]

  // v3.1 Engagement & intelligence
  confidenceRatings  ConfidenceRating[]
  seasonPassProgress SeasonPassProgress[]
  dailyBoosts        DailyBoost[]
  studyGroupMembers  StudyGroupMember[]
  questionPosts      QuestionPost[]
  questionVotes      QuestionVote[]
  marketplaceListings MarketplaceListing[]
  teacherSettings    TeacherSettings?

  // v4 Game store & district
  gamePurchases      GamePurchase[]
  gameSessions       GameSession[]
  districtAdmins     DistrictAdmin[]
  classroomStudents  ClassroomStudent[]
  fileUploads        FileUpload[]

  // Auth sessions
  sessions       Session[]
  accounts       Account[]

  // Messaging
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  // Security & Compliance (v8.10)
  childConsents    ParentalConsent[]  @relation("ChildConsents")
  parentConsents   ParentalConsent[]  @relation("ParentConsents")
  dataAccessedBy   DataAccessLog[]    @relation("DataAccessor")
  dataAccessedOf   DataAccessLog[]    @relation("DataSubject")
  deletionRequested  DataDeletionRequest[] @relation("DeletionRequestor")
  deletionSubjectOf  DataDeletionRequest[] @relation("DeletionSubject")

  @@index([email])
  @@index([role])
  @@index([districtId])
  @@index([parentId])
  @@index([schoolId])
  @@map("users")
}

// ─── AUTH (NextAuth.js) ─────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── COURSE ─────────────────────────────────────────────────────────────────

model Course {
  id          String      @id @default(cuid())
  name        String
  description String?
  subject     String
  gradeLevel  String
  districtId  String
  isActive    Boolean     @default(true)
  standards   String?     @db.Text  // JSON: aligned standards (Common Core, NGSS, etc.)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  district    SchoolDistrict @relation(fields: [districtId], references: [id], onDelete: Cascade)
  teachers    CourseTeacher[]
  enrollments Enrollment[]
  assignments Assignment[]
  skillRecords SkillRecord[]

  @@index([districtId])
  @@map("courses")
}

model CourseTeacher {
  id        String   @id @default(cuid())
  courseId   String
  teacherId  String
  assignedAt DateTime @default(now())

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher User   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([courseId, teacherId])
  @@map("course_teachers")
}

model Enrollment {
  id         String   @id @default(cuid())
  courseId    String
  studentId  String
  enrolledAt DateTime @default(now())

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@map("enrollments")
}

// ─── ASSIGNMENT ─────────────────────────────────────────────────────────────

model Assignment {
  id            String         @id @default(cuid())
  title         String
  description   String         @db.Text
  type          AssignmentType
  courseId       String
  createdById    String
  dueDate       DateTime
  totalPoints   Int            @default(100)
  rubric        String?        @db.Text  // JSON rubric for AI grading
  isPublished   Boolean        @default(false)
  allowLateSubmission Boolean  @default(false)
  difficulty    Difficulty     @default(MEDIUM)
  skills        String?        @db.Text  // JSON array of skill tags
  standards     String?        @db.Text  // JSON aligned standards
  // v9.4.0: Adaptive learning
  workMode      String         @default("in_class")  // "in_class" | "homework" | "independent_practice"
  adaptiveEnabled Boolean      @default(false)        // When true, AI adapts per student learning style
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  course     Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy  User        @relation(fields: [createdById], references: [id], onDelete: Cascade)
  submissions Submission[]
  adaptedVersions AdaptedAssignment[]

  @@index([courseId])
  @@index([dueDate])
  @@map("assignments")
}

// ─── SUBMISSION ─────────────────────────────────────────────────────────────

model Submission {
  id            String           @id @default(cuid())
  assignmentId  String
  studentId     String
  content       String           @db.Text  // The student's answer
  status        SubmissionStatus @default(PENDING)
  score         Float?
  maxScore      Float?
  aiFeedback    String?          @db.Text  // AI-generated personalized feedback
  teacherNotes  String?          @db.Text  // Teacher override/additional notes
  misconceptions String?        @db.Text  // JSON: AI-detected misconceptions
  gradedAt      DateTime?
  submittedAt   DateTime?
  timeSpentSec  Int?             // Time student spent
  // v9.4.0: Learning method tracking
  solvingMethod   String?        // "visual" | "step_by_step" | "audio_based" | "simplified" | "structured" | "interactive"
  methodDetails   String?        @db.Text  // JSON: detailed breakdown of how student solved the work
  adaptedFrom     String?        // ID of AdaptedAssignment used (if any)
  // File upload support
  fileUploadIds String?          @db.Text  // JSON array of FileUpload IDs
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mistakeEntries MistakeEntry[]

  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@index([status])
  @@map("submissions")
}

// ─── ADAPTED ASSIGNMENT (v9.4.0 — Per-Student Personalized Versions) ────

model AdaptedAssignment {
  id               String   @id @default(cuid())
  assignmentId     String
  studentId        String
  adaptedContent   String   @db.Text  // AI-transformed assignment content
  learningStyle    String              // Primary style used: "visual", "auditory", "adhd_friendly", "structured", "kinesthetic", "reading_writing"
  adaptations      String   @db.Text  // JSON: { modifications: [], scaffolding: [], format_changes: [] }
  methodSuggestion String?             // Suggested solving method for this student
  difficulty       String?             // Adjusted difficulty: "simplified", "standard", "enriched"
  createdAt        DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@map("adapted_assignments")
}

// ─── FILE UPLOAD ──────────────────────────────────────────────────────────

model FileUpload {
  id            String   @id @default(cuid())
  userId        String
  fileName      String
  originalName  String
  mimeType      String
  fileSize      Int      // bytes
  fileData      String   @db.Text  // Base64 encoded for small files, or URL for large
  purpose       String   @default("submission") // "submission", "assignment", "profile"
  submissionId  String?  // Optional link to submission
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([submissionId])
  @@map("file_uploads")
}

// ─── AI TUTOR LOG ───────────────────────────────────────────────────────────

model AITutorLog {
  id          String   @id @default(cuid())
  userId      String
  sessionId   String   // Groups messages in a conversation
  role        String   // "user" | "assistant" | "system"
  content     String   @db.Text
  subject     String?  // What subject the question relates to
  personality String?  // Tutor personality used: socratic, friendly, strict, creative
  tokensUsed  Int      @default(0)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId])
  @@index([createdAt])
  @@map("ai_tutor_logs")
}

// ─── GAMIFICATION / REWARD STATS ────────────────────────────────────────────

model RewardStats {
  id               String   @id @default(cuid())
  userId           String   @unique
  totalXP          Int      @default(0)
  level            Int      @default(1)
  currentStreak    Int      @default(0)
  longestStreak    Int      @default(0)
  lastActiveDate   DateTime @default(now())
  virtualCoins     Int      @default(0)
  unlockedAvatars  String   @default("[]") // JSON array of unlocked avatar IDs
  unlockedBadges   String   @default("[]") // JSON array of badge IDs
  unlockedThemes   String   @default("[]") // JSON array of theme IDs
  assignmentsCompleted Int  @default(0)
  tutorSessionsCount   Int  @default(0)
  perfectScores    Int      @default(0)
  totalStudyMinutes Int     @default(0)
  leaguePoints     Int      @default(0)
  seasonRank       Int?     // Current season ranking
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reward_stats")
}

// ─── NOTIFICATIONS ──────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // "assignment", "grade", "achievement", "system", "alert", "challenge"
  isRead    Boolean  @default(false)
  link      String?  // Optional navigation link
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── CERTIFICATES ───────────────────────────────────────────────────────────

model Certificate {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  type        String   // "course_completion", "achievement", "milestone"
  metadata    String?  @db.Text  // JSON with additional data
  issuedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("certificates")
}

// ─── MESSAGES (Parent-Teacher Communication) ────────────────────────────────

model Message {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  subject     String
  content     String   @db.Text
  isRead      Boolean  @default(false)
  parentOf    String?  // Student ID this message is about
  createdAt   DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}

// ═══════════════════════════════════════════════════════════════════════════
// NEW: ADAPTIVE LEARNING & COGNITIVE SCIENCE ENGINE
// ═══════════════════════════════════════════════════════════════════════════

// ─── SKILL TRACKING ────────────────────────────────────────────────────────

model SkillRecord {
  id             String   @id @default(cuid())
  userId         String
  courseId        String?
  skillName      String   // e.g., "Fractions", "Photosynthesis", "Essay Structure"
  skillCategory  String   // e.g., "Math", "Science", "ELA"
  masteryLevel   Float    @default(0)  // 0-100 mastery percentage
  totalAttempts  Int      @default(0)
  correctAttempts Int     @default(0)
  currentDifficulty Difficulty @default(MEDIUM)
  lastPracticed  DateTime @default(now())
  nextReview     DateTime @default(now()) // spaced rep next review
  easeFactor     Float    @default(2.5)  // SM-2 algorithm ease factor
  interval       Int      @default(1)    // days until next review
  repetitions    Int      @default(0)
  streak         Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@unique([userId, skillName, courseId])
  @@index([userId, nextReview])
  @@index([userId, skillCategory])
  @@map("skill_records")
}

// ─── SPACED REPETITION ITEMS ───────────────────────────────────────────────

model SpacedRepItem {
  id            String   @id @default(cuid())
  userId        String
  question      String   @db.Text
  answer        String   @db.Text
  skillName     String
  subject       String
  difficulty    Difficulty @default(MEDIUM)
  easeFactor    Float    @default(2.5)
  interval      Int      @default(1)    // days
  repetitions   Int      @default(0)
  nextReview    DateTime @default(now())
  lastReview    DateTime?
  lastQuality   Int?     // 0-5 quality of last response
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, nextReview])
  @@index([userId, subject])
  @@map("spaced_rep_items")
}

// ─── STUDY PLANNER ─────────────────────────────────────────────────────────

model StudyPlanSession {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime // planned date
  subject       String
  topic         String
  goalMinutes   Int      @default(30)
  actualMinutes Int      @default(0)
  completed     Boolean  @default(false)
  sessionType   String   @default("study") // "study", "review", "practice", "exam_prep"
  difficulty    Difficulty @default(MEDIUM)
  notes         String?  @db.Text
  aiRecommended Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

