# ─────────────────────────────────────────────────────────────
# Limud v8.4.1 — .htaccess for GoDaddy cPanel + Node.js
# ─────────────────────────────────────────────────────────────
# GoDaddy cPanel uses Phusion Passenger to run Node.js apps.
# This file ensures Apache correctly routes requests to the
# Node.js application and handles static assets efficiently.
# ─────────────────────────────────────────────────────────────

# Enable Passenger for Node.js
PassengerEnabled on
PassengerAppType node
PassengerStartupFile server.js
PassengerNodejs /home/YOUR_CPANEL_USER/nodevenv/limud/20/bin/node

# ─── GZIP Compression ─────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE application/xml text/xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/x-font-ttf font/opentype
</IfModule>

# ─── Browser Caching ──────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  # Static assets — cache aggressively (1 year)
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/x-font-ttf "access plus 1 year"
  ExpiresByType font/opentype "access plus 1 year"
  # HTML — short cache (Next.js handles its own caching)
  ExpiresByType text/html "access plus 0 seconds"
  # JSON API responses — no cache
  ExpiresByType application/json "access plus 0 seconds"
</IfModule>

# ─── Security Headers ─────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  # Remove server signature
  Header always unset X-Powered-By
  Header always unset Server
</IfModule>

# ─── Force HTTPS ───────────────────────────────────────────
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── Remove www (optional — uncomment if you prefer non-www) ──
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# ─── Serve Next.js static assets directly from public/ ────
# This bypasses Node.js for static files = much faster
RewriteCond %{REQUEST_URI} ^/favicon\.ico$ [OR]
RewriteCond %{REQUEST_URI} ^/manifest\.json$ [OR]
RewriteCond %{REQUEST_URI} ^/sw\.js$ [OR]
RewriteCond %{REQUEST_URI} ^/robots\.txt$ [OR]
RewriteCond %{REQUEST_URI} ^/sitemap\.xml$
RewriteRule ^(.*)$ public/$1 [L]

# ─── Error Pages ───────────────────────────────────────────
ErrorDocument 503 "Limud is starting up. Please refresh in a moment."
